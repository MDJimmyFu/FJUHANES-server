            window.open(url2, \"_blank\");\r\n\r\n        };\r\n\r\n        function load_page3(url) {\r\n            // var ifrmae = document.getElementById('EKG');\r\n            //  window.frames['EKG'].location = url2;\r\n            window.open(url, \"_blank\");\r\n\r\n        };\r\n\r\n        function load_page4(url) {\r\n            document.getElementById(\"myDialog\").showModal();\r\n\r\n        };\r\n\r\n        function changeLabel(url) {\r\n\r\n        };\r\n\r\n        function Check(url) {\r\n            var win = window.open(url);\r\n        };\r\n\r\n        function load_pageaa(url) {\r\n            var ifrmae = document.getElementById('iframe');\r\n            window.frames['iframe'].location = url;\r\n            document.body.style.cursor = \"default\";\r\n        }\r\n\r\n        function setHourglass() {\r\n            document.body.style.cursor = \"wait\";\r\n        };\r\n\r\n        /*\u7d22\u5f15\u6b04\u4f4d\u9577\u5ea6\u4e0d\u5920\u88dc0\u81f310\u4f4d\u6578 */\r\n        function Changed(textControl) {\r\n            var text = textControl.value;\r\n            var str = '' + text.toUpperCase();\r\n            while (str.length < 10) {\r\n                str = '0' + str;\r\n            }\r\n            textControl.value = str;\r\n        };\r\n\r\n        var oldColor;//\u7d00\u9304\u539f\u672c\u984f\u8272\r\n        function SetNewColor(row) {//Gridview\u8b8a\u8272\u6548\u679c\r\n\r\n            oldColor = row.style.backgroundColor;\r\n            alert(oldColor);\r\n            // row.style.backgroundColor = '#EEFE96';  //\u9019\u662f\u8981\u8b8a\u5316\u7684\u984f\u8272\r\n\r\n            if (row.style.backgroundColor = oldColor) {\r\n                row.style.backgroundColor = '#EEFE96';\r\n                alert(row.style.backgroundColor);\r\n            } else {\r\n                row.style.backgroundColor = '#F0F0F0';\r\n                alert(row.style.backgroundColor);\r\n            }\r\n\r\n        }\r\n\r\n        function SetOldColor(row) {\r\n\r\n        }\r\n\r\n    </script>\r\n    \r\n    <script type=\"text/javascript\">\r\n        $(function () {\r\n            $(\"[id*=OpdOrderReport] td\").bind(\"click\", function () {\r\n                var row = $(this).parent();\r\n                $(\"[id*=OpdOrderReport] tr\").each(function () {\r\n                    if ($(this)[0] != row[0]) {\r\n                        $(\"td\", this).removeClass(\"selected_row\");\r\n                    }\r\n                });\r\n                $(\"td\", row).each(function () {\r\n                    if (!$(this).hasClass(\"selected_row\")) {\r\n                        $(this).addClass(\"selected_row\");\r\n                    } else {\r\n                        $(this).removeClass(\"selected_row\");\r\n                    }\r\n                });\r\n            });\r\n        });\r\n    </script>\r\n    <script type=\"text/javascript\">\r\n        $(function () {\r\n            $(\"[id*=OPDReport] td\").bind(\"click\", function () {\r\n                var row = $(this).parent();\r\n                $(\"[id*=OPDReport] tr\").each(function () {\r\n                    if ($(this)[0] != row[0]) {\r\n                        $(\"td\", this).removeClass(\"selected_row\");\r\n                    }\r\n                });\r\n                $(\"td\", row).each(function () {\r\n                    if (!$(this).hasClass(\"selected_row\")) {\r\n                        $(this).addClass(\"selected_row\");\r\n                    } else {\r\n                        $(this).removeClass(\"selected_row\");\r\n                    }\r\n                });\r\n            });\r\n        });\r\n    </script>\r\n    <style>\r\n     .selected_row\r\n    {\r\n        background-color: #B1CBE2;\r\n    }\r\n     \r\n\r\n    body {\r\n        margin-top: 0px;\r\n    }\r\n\r\n    table {\r\n        width: 100%;\r\n    }\r\n\r\n    #ajaxContainer {\r\n         width: 100%; \r\n\t\t/*width: 630px;*/\r\n          height: 725px; \r\n    }\r\n\r\n    #iframeContainer {\r\n        width: 100%;\r\n        background-color: #F0F0F0;;\r\n\t\t float:left;\r\n        height: 650px;\r\n    }\r\n\r\n    #QueryForm {\r\n        width: 100%;\r\n        height: 30px;\r\n        background-image: url(img/QueryForm_bg.jpg);\r\n        padding: 5px;\r\n        cursor: default; /*\u6ed1\u9f20\u6e38\u6a19\u5716\u6848*/\r\n    }\r\n\r\n    .TabStyle .ajax__tab_header {\r\n        /*\u6574\u9ad4\u6309\u9215\u5e95*/\r\n        background-color: #F0F0F0;\r\n        font-size: 16px;\r\n        height: 30px;\r\n        font-family: PMingLiU;\r\n        border-bottom: 1px solid #666666;\r\n        color: #000000;\r\n        cursor: default; /*\u6ed1\u9f20\u6e38\u6a19\u5716\u6848*/\r\n    }\r\n\r\n    .TabStyle .ajax__tab_body {\r\n        /*\u8cc7\u6599\u5340*/\r\n        border: 0px solid #800000; /*\u908a\u6846*/\r\n        padding: 1px; /*\u6587\u5b57\u8207\u908a\u6846\u9593\u9694*/\r\n        background-color: #ADADAD; /*#ADADAD;/*\u80cc\u666f\u984f\u8272:\u6de1\u7070\u8272*/\r\n         Height: 500px; \r\n    }\r\n\r\n    .TabStyle .ajax__tab_active .ajax__tab_tab {\r\n        /*\u4f7f\u7528\u4e2d*/\r\n        border: 1px solid;\r\n        border-color: #bebebe #bebebe #e1e1e1 #bebebe; /*\u908a\u6846\u984f\u8272*/\r\n        background-color: #F0F0F0;\r\n        padding: 5px; /*padding \u5167\u8ddd\u7684\u8a2d\u5b9a\uff0c\u53ef\u4ee5\u63a7\u5236\u5340\u57df\u5982 DIV \u6216 span \u7684\u5167\u90e8\u8ddd\u96e2*/\r\n        border-bottom: none;\r\n        color: #000000;\r\n        cursor: default; /*\u6ed1\u9f20\u6e38\u6a19\u5716\u6848*/\r\n    }\r\n\r\n        .TabStyle .ajax__tab_active .ajax__tab_tab:hover {\r\n            /*\u63a7\u5236tab\u9078\u55ae-->\u88ab\u9078\u53d6\u5f8c,\u518d\u5ea6\u9078\u53d6\u9019\u500b\u6309\u9215\u7684\u683c\u5f0f*/\r\n            cursor: default;\r\n            font-family: PMingLiU;\r\n            border: 1px solid;\r\n            border-color: #bebebe #bebebe #e1e1e1 #F0F0F0;\r\n            background-color: #F0F0F0;\r\n            padding: 5px;\r\n            border-bottom: none;\r\n            color: #000000;\r\n        }\r\n\r\n    .TabStyle .ajax__tab_tab:hover {\r\n        /*\u63a7\u5236tab\u9078\u55ae-->\u6ed1\u9f20\u79fb\u904e\u53bb\u7684\u6309\u9215\u683c\u5f0f*/\r\n        cursor: default;\r\n        font-family: PMingLiU;\r\n        border: 1px solid;\r\n        border-color: #bebebe #bebebe #e1e1e1 #bebebe;\r\n        background-color: #e1e1e1;\r\n        padding: 3px;\r\n        border-bottom: none;\r\n        color: #000000;\r\n    }\r\n\r\n    .TabStyle .ajax__tab_tab {\r\n        /*\u63a7\u5236tab\u9078\u55ae-->\u6309\u9215\u9810\u8a2d\u7684\u683c\u5f0f*/\r\n        cursor: default;\r\n        padding: 2px;\r\n        border: 1px solid;\r\n        border-color: #bebebe #bebebe #e1e1e1 #bebebe;\r\n        background-color: #e1e1e1;\r\n    }\r\n\r\n    .TabStyle .ajax__tab_header .ajax__tab_tab {\r\n        /*\u63a7\u5236tab\u9078\u55ae-->\u6309\u9215\u5f7c\u6b64\u4e4b\u9593\u7684\u8ddd\u96e2*/\r\n        margin: 0px 0px 0px 0px;\r\n    }\r\n\r\n    .GridViewHeaderStyle {\r\n        text-align: left;\r\n        font-family: PMingLiU;\r\n        font-size: 16px;\r\n        text-decoration: none;\r\n        background-color: #F0F0F0;\r\n        padding-bottom: 2px;\r\n        padding-left: 2px;\r\n        padding-right: 2px;\r\n        padding-top: 1px; /*padding \u5167\u8ddd\u7684\u8a2d\u5b9a\uff0c\u53ef\u4ee5\u63a7\u5236\u5340\u57df\u5982 DIV \u6216 span \u7684\u5167\u90e8\u8ddd\u96e2*/\r\n        border-bottom: none;\r\n        color: #000000;\r\n    }\r\n\r\n        .GridViewHeaderStyle th {\r\n            text-align: left;\r\n            font-family: PMingLiU;\r\n            font-size: 16px;\r\n            font-weight: normal;\r\n            background-color: #F0F0F0;\r\n            padding-bottom: 2px;\r\n            padding-left: 2px;\r\n            padding-right: 2px;\r\n            padding-top: 1px; /*padding \u5167\u8ddd\u76